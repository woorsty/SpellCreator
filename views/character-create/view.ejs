<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Character Creator</title>
  <style>
    * {
      box-sizing: border-box
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f1f5f9;
      color: #111827
    }

    .layout {
      display: grid;
      grid-template-columns: 280px 1fr 320px;
      gap: 24px;
      padding: 24px;
      min-height: 100vh
    }

    .card {
      background: #fff;
      border-radius: 18px;
      padding: 20px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, .08)
    }

    .steps .step {
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 8px;
      background: #fff;
      border: 1px solid #e5e7eb
    }

    .steps .active {
      background: #111827;
      color: #fff;
      border-color: #111827
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px
    }

    input,
    select,
    textarea,
    button {
      width: 100%;
      padding: 12px;
      border-radius: 12px;
      border: 1px solid #d1d5db;
      font-size: 14px
    }

    textarea {
      min-height: 160px;
      resize: vertical
    }

    button {
      cursor: pointer;
      background: #111827;
      color: #fff;
      border: none
    }

    button.secondary {
      background: #fff;
      color: #111827;
      border: 1px solid #d1d5db
    }

    .actions {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-top: 24px
    }

    .option {
      padding: 14px;
      border: 1px solid #d1d5db;
      border-radius: 14px;
      cursor: pointer
    }

    .option.active {
      border-color: #111827;
      background: #eef2ff
    }

    .preview div {
      margin-bottom: 8px
    }

    .progress {
      height: 10px;
      background: #e5e7eb;
      border-radius: 99px;
      overflow: hidden;
      margin: 12px 0 18px
    }

    .progress span {
      display: block;
      height: 100%;
      background: #111827
    }

    label.check {
      display: flex;
      gap: 8px;
      align-items: center;
      padding: 10px;
      border: 1px solid #d1d5db;
      border-radius: 12px
    }
  </style>
</head>

<body>
  <div class="layout">
    <aside class="card steps">
      <h2>Charakter erstellen</h2>
      <div class="progress"><span id="progressBar"></span></div>
      <div id="stepList"></div>
    </aside>

    <main class="card">
      <div id="stepContent"></div>
      <div class="actions">
        <button class="secondary" id="prevBtn">Zurück</button>
        <button id="nextBtn">Weiter</button>
      </div>
    </main>

    <aside class="card preview">
      <h3>Live Vorschau</h3>
      <div id="preview"></div>
    </aside>
  </div>

  <script>
    const steps = ['Basis', 'Klasse', 'Attribute', 'Skills', 'Ausrüstung', 'Zauber', 'Story'];
    let step = 0;
    const character = {
      name: '',
      species: 'Human',
      class: 'Fighter',
      level: 1,
      background: '',
      alignment: 'Neutral',
      attributes: {
        STR: 15,
        DEX: 14,
        CON: 13,
        INT: 12,
        WIS: 10,
        CHA: 8
      },
      skills: [],
      equipment: [],
      spells: [],
      backstory: ''
    };
    const mod = v => Math.floor((v - 10) / 2);

    function render() {
      renderSteps();
      renderContent();
      renderPreview();
    }

    function renderSteps() {
      document.getElementById('stepList').innerHTML = steps.map((s, i) => `<div class="step ${i===step?'active':''}">${i+1}. ${s}</div>`).join('');
      document.getElementById('progressBar').style.width = ((step + 1) / steps.length * 100) + '%';
    }

    function renderContent() {
      const el = document.getElementById('stepContent');
      if (step === 0) el.innerHTML = `<div class='grid2'><input id='name' placeholder='Name' value='${character.name}'><select id='species'><option>Human</option><option>Elf</option><option>Dwarf</option><option>Halfling</option></select><input id='background' placeholder='Background' value='${character.background}'></div>`;
      if (step === 1) el.innerHTML = `<div class='grid2'>${['Fighter','Wizard','Rogue','Cleric','Bard','Druid'].map(c=>`<div class='option ${character.class===c?'active':''}' onclick="character.class='${c}';render()">${c}</div>`).join('')}</div>`;
      if (step === 2) el.innerHTML = `<div class='grid2'>${Object.keys(character.attributes).map(a=>`<div><label>${a}</label><input type='number' value='${character.attributes[a]}' onchange="character.attributes.${a}=Number(this.value);render()"><small>Mod ${mod(character.attributes[a])>=0?'+':''}${mod(character.attributes[a])}</small></div>`).join('')}</div>`;
      if (step === 3) el.innerHTML = `<div class='grid2'>${['Athletics','Stealth','Arcana','Perception','Persuasion','History'].map(s=>`<label class='check'><input type='checkbox' ${character.skills.includes(s)?'checked':''} onchange="toggle('skills','${s}')">${s}</label>`).join('')}</div>`;
      if (step === 4) el.innerHTML = `<div class='grid2'>${['Backpack','Rope','Rations','Longsword','Shield','Spellbook'].map(s=>`<label class='check'><input type='checkbox' ${character.equipment.includes(s)?'checked':''} onchange="toggle('equipment','${s}')">${s}</label>`).join('')}</div>`;
      if (step === 5) el.innerHTML = `<div class='grid2'>${['Fire Bolt','Mage Armor','Healing Word','Guidance','Sleep','Magic Missile'].map(s=>`<label class='check'><input type='checkbox' ${character.spells.includes(s)?'checked':''} onchange="toggle('spells','${s}')">${s}</label>`).join('')}</div>`;
      if (step === 6) el.innerHTML = `<input id='alignment' placeholder='Alignment' value='${character.alignment}'><textarea id='backstory' placeholder='Backstory'>${character.backstory}</textarea>`;
      setTimeout(bindInputs, 0);
    }

    function bindInputs() {
      if (document.getElementById('name')) document.getElementById('name').oninput = e => character.name = e.target.value;
      if (document.getElementById('species')) document.getElementById('species').onchange = e => character.species = e.target.value;
      if (document.getElementById('background')) document.getElementById('background').oninput = e => character.background = e.target.value;
      if (document.getElementById('alignment')) document.getElementById('alignment').oninput = e => character.alignment = e.target.value;
      if (document.getElementById('backstory')) document.getElementById('backstory').oninput = e => character.backstory = e.target.value;
    }

    function renderPreview() {
      document.getElementById('preview').innerHTML = `<div><strong>${character.name||'Unbenannt'}</strong></div><div>${character.species} ${character.class}</div><div>Level ${character.level}</div><div>HP ${10+mod(character.attributes.CON)}</div><div>AC ${10+mod(character.attributes.DEX)}</div><div>Skills: ${character.skills.join(', ')||'-'}</div><div>Zauber: ${character.spells.join(', ')||'-'}</div>`;
    }

    function toggle(key, val) {
      const arr = character[key];
      const i = arr.indexOf(val);
      if (i >= 0) arr.splice(i, 1);
      else arr.push(val);
      render();
    }
    document.getElementById('nextBtn').onclick = () => {
      if (step < steps.length - 1) {
        step++;
        render();
      } else alert('Charakter fertig!');
    };
    document.getElementById('prevBtn').onclick = () => {
      if (step > 0) {
        step--;
        render();
      }
    };
    render();
  </script>
</body>

</html>