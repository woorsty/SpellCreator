<% /* Character Creator - Server Rendered (No JS, TypeScript Backend Friendly) */ %>
<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Charakter erstellen</title>
  <style>
    :root {
      --bg: #1e1f22;
      --panel: #2b2d31;
      --panel2: #33363c;
      --line: #4b4f57;
      --text: #f5f5f5;
      --muted: #b8bcc5;
      --accent: #3b82f6;
    }

    * {
      box-sizing: border-box
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .layout {
      display: grid;
      grid-template-columns: 260px 1fr 320px;
      gap: 16px;
      padding: 20px;
      min-height: 100vh;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
    }

    h2,
    h3 {
      margin: 0 0 12px 0
    }

    .step {
      display: block;
      padding: 10px;
      border-radius: 10px;
      border: 1px solid var(--line);
      margin-bottom: 8px;
      text-decoration: none;
      color: var(--text);
      background: var(--panel2);
    }

    .step.active {
      border-color: var(--accent)
    }

    input,
    select,
    textarea,
    button {
      width: 100%;
      padding: 10px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: var(--panel2);
      color: var(--text);
      font: inherit;
    }

    textarea {
      min-height: 140px
    }

    button {
      background: var(--accent);
      border: none;
      cursor: pointer;
    }

    .grid2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px
    }

    .choice {
      display: block;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 10px;
      margin-bottom: 8px;
      text-decoration: none;
      color: var(--text);
      background: var(--panel2);
    }

    .choice.active {
      border-color: var(--accent)
    }

    .preview div {
      margin-bottom: 6px
    }

    .muted {
      color: var(--muted);
      font-size: 12px
    }
  </style>
</head>

<body>

  <%
const step = Number(typeof startstep !== 'undefined' ? startstep : 0);
const character = typeof characterDraft !== 'undefined' && characterDraft ? characterDraft : {
  name:'',background:'',class:'Fighter',species:'Human',
  strength:{value:10,modifier:0},dexterity:{value:10,modifier:0},constitution:{value:10,modifier:0},intelligence:{value:10,modifier:0},wisdom:{value:10,modifier:0},charisma:{value:10,modifier:0},
  skills:[],equipment:[],alignment:'Neutral',backstory:''
};
const steps = ['Charakterdaten','Klasse & Volk','Attribute','Fertigkeiten','Ausrüstung','Hintergrund & Gesinnung'];
%>

  <div class="layout">

    <aside class="card">
      <h2>Charakter erstellen</h2>
      <% steps.forEach((s,i)=>{ %>
      <a class="step <%= i===step?'active':'' %>" href="?step=<%= i %>"><%= i+1 %>. <%= s %></a>
      <% }) %>
    </aside>

    <main class="card">

      <form method="POST" action="/characters/create?step=<%= step %>">

        <% if(step===0){ %>
        <h3>Charakterdaten</h3>
        <input name="name" value="<%= character
    .name %>" placeholder="Name" />
        <input name="background" value="<%= character
    .background %>" placeholder="Hintergrund" />
        <% } %>

        <% if(step===1){ %>
        <h3>Klasse & Volk</h3>
        <input name="species" value="<%= character
    .species %>" placeholder="Volk" />
        <% ['Fighter','Wizard','Rogue','Cleric','Bard','Druid'].forEach(x=>{ %>
        <label class="choice <%= character
    .class===x?'active':'' %>">
          <input type="radio" name="class" value="<%= x %>" <%= character
        .class===x?'checked':'' %> /> <%= x %>
        </label>
        <% }) %>
        <% } %>

        <% if(step===2){ %>
        <h3>Attribute</h3>
        <% ['strength','dexterity','constitution','intelligence','wisdom','charisma'].forEach(a=>{ %>
        <div>
          <label><%= a %></label>
          <input type="number" name="<%= a %>" value="<%= character
        [a].value %>" />
        </div>
        <% }) %>
        <% } %>

        <% if(step===3){ %>
        <h3>Fertigkeiten</h3>
        <% ['athletics','stealth','arcana','perception','persuasion'].forEach(s=>{ %>
        <label class="choice">
          <input type="checkbox" name="skills" value="<%= s %>" <%= character[s].proficiency?'checked':'' %> /> <%= s %>
        </label>
        <% }) %>
        <% } %>

        <% if(step===4){ %>
        <h3>Ausrüstung</h3>
        <% ['Backpack','Rope','Rations','Sword','Shield'].forEach(s=>{ %>
        <label class="choice">
          <input type="checkbox" name="equipment" value="<%= s %>" <%= character
        .equipment.includes(s)?'checked':'' %> /> <%= s %>
        </label>
        <% }) %>
        <% } %>

        <% if(step===5){ %>
        <h3>Hintergrund & Gesinnung</h3>
        <input name="alignment" value="<%= character
    .alignment %>" placeholder="Gesinnung" />
        <textarea name="backstory" placeholder="Hintergrundgeschichte"><%= character
    .backstory %></textarea>
        <% } %>

        <button type="submit">Weiter</button>
      </form>

    </main>

    <aside class="card preview">
      <h3>Charaktervorschau</h3>
      <div><b><%= character
    .name || 'Unbenannt' %></b></div>
      <div><%= character
    .species %> <%= character
    .class %></div>
      <div>Stärke <%= character
    .strength.value %></div>
      <div>Geschicklichkeit <%= character
    .dexterity.value %></div>
      <div>Konstitution <%= character
    .constitution.value %></div>
    </aside>

  </div>

</body>

</html>