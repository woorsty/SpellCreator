<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= character.name %> – Charakterbogen</title>

  <style>
    :root {
      --bg: #1e1f22;
      --panel: #2b2d31;
      --panel2: #33363c;
      --line: #4b4f57;
      --text: #f5f5f5;
      --muted: #b8bcc5;
      --green: #57d37c;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, Helvetica, sans-serif;
    }

    a {
      color: var(--text);
    }

    .sheet {
      max-width: 1600px;
      margin: auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
    }

    .section-title {
      margin: 0 0 12px 0;
      font-size: 16px;
      font-weight: 700;
      border-bottom: 1px solid var(--line);
      padding-bottom: 8px;
    }

    .label {
      font-size: 12px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .value {
      font-size: 18px;
      font-weight: 700;
    }

    .top {
      display: grid;
      grid-template-columns: 3fr 1fr 1.4fr 1.2fr;
      gap: 10px;
      align-items: stretch;
    }

    .top .label {
      font-size: 10px;
      margin-bottom: 2px;
    }

    .top .value {
      font-size: 14px;
      font-weight: 600;
    }

    .top .card {
      padding: 10px;
      border-radius: 10px;
    }

    .top .quickbox {
      padding: 10px;
    }

    .sheet {
      max-width: 100%;
    }

    .page {
      display: grid;
      grid-template-columns: 440px minmax(520px, 1fr) 360px;
      gap: 14px;
      align-items: start;
    }

    .firstpage {
      display: grid;
      grid-template-columns: 480px 1fr;
      gap: 14px;
      align-items: start;
    }

    .left,
    .center,
    .right {
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-self: start;
    }

    .abilities {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .ability {
      overflow: hidden;
      background: var(--panel2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    .ability-name {
      font-size: 14px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .ability-score {
      font-size: 32px;
      font-weight: 700;
      margin-top: 8px;
    }

    .ability-mod {
      font-size: 18px;
      color: var(--green);
    }

    .ability-proficiency {
      font-size: 18px;
    }

    .quickstats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .quickbox .label {
      display: block;
      margin-bottom: 8px;
      font-size: 12px;
    }

    .quickbox .value {
      display: block;
      font-size: 20px;
      font-weight: 700;
    }

    .quickbox {
      background: var(--panel2);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th,
    td {
      padding: 8px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    th {
      color: var(--muted);
      font-size: 13px;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .grid-2-small {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0px;
    }

    .list {
      margin: 0;
      padding-left: 18px;
    }

    .list li {
      margin-bottom: 6px;
    }

    .money {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
    }

    .money .quickbox {
      padding: 10px;
    }

    .spellslots-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .slot-card {
      background: var(--panel2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px;
    }

    .slot-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .slot-right {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .slot-count {
      font-size: 22px;
      font-weight: 700;
      min-width: 20px;
      text-align: right;
    }

    .slot-gems {
      display: grid;
      grid-template-columns: repeat(4, 14px);
      gap: 6px;
    }

    .slot-grade {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .gem {
      width: 100%;
      aspect-ratio: 1/1;
      transform: rotate(45deg);
      border-radius: 3px;
    }

    /* verfügbar = leer */
    .gem.free {
      border: 2px solid #ddd;
      background: transparent;
    }

    /* genutzt = ausgefüllt */
    .gem.used {
      border: 2px solid #f5f5f5;
      background: #f5f5f5;
    }

    /* nicht vorhandene Slots unsichtbar */
    .gem.hidden {
      visibility: hidden;
    }

    textarea.fake {
      width: 100%;
      min-height: 180px;
      resize: none;
      border: none;
      background: var(--panel2);
      color: var(--text);
      border-radius: 12px;
      padding: 12px;
    }

    .ability {
      text-align: left;
    }

    .skill-row {
      display: grid;
      grid-template-columns: 22px 60px 1fr;
      gap: 8px;
      min-width: 0;
      align-items: center;
      padding: 2px 0;
      border-bottom: 1px solid rgba(255, 255, 255, .06);
    }

    .skill-row:last-child {
      border-bottom: none;
    }

    .skill-check {
      width: 18px;
      height: 18px;
      border: 2px solid #d9d9d9;
      border-radius: 50%;
      margin: auto;
      position: relative;
    }

    .skill-check.filled::after {
      content: "";
      position: absolute;
      inset: 3px;
      border-radius: 50%;
      background: #f5f5f5;
    }

    .skill-mod {
      font-weight: 700;
      color: var(--green);
      text-align: center;
    }

    .skill-name {
      font-size: 14px;
      min-width: 0;
      white-space: normal;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .abilities {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      align-items: start;
    }

    .abilities-left,
    .abilities-right {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    /* Übungsbonus + Heroic Inspiration */
    .mini-stat {
      background: var(--panel2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    .heroic-circle {
      width: 22px;
      height: 22px;
      border: 2px solid #ddd;
      border-radius: 50%;
      margin: 8px auto 0;
    }

    .heroic-circle.filled::after {
      content: "";
      display: block;
      width: 12px;
      height: 12px;
      margin: 3px auto;
      border-radius: 50%;
      background: #fff;
    }

    .ability-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin: 10px 0 14px;
    }

    .ability-statbox {
      background: rgba(255, 255, 255, .05);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 8px;
      text-align: center;
    }

    .ability-stat-label {
      font-size: 11px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .ability-stat-value {
      font-size: 28px;
      font-weight: 700;
      line-height: 1;
    }

    .ability-stat-mod {
      font-size: 24px;
      font-weight: 700;
      color: var(--green);
      line-height: 1;
    }

    .character-info .label {
      display: block;
      margin-bottom: 5px;
      font-size: 10px;
    }

    .character-info .value {
      display: block;
      font-size: 14px;
      font-weight: 700;
    }

    .character-info {
      background: var(--panel2);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    .death-saves {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .death-column {
      background: var(--panel2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 8px;
      text-align: center;
    }

    .death-label {
      font-size: 12px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .death-row {
      display: flex;
      justify-content: center;
      gap: 4px;
    }

    .training-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    .training-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .tool-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    /* PAGE 2 */
    .page-two {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 14px;
      align-items: start;
    }

    .page-two-left,
    .page-two-right {
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-width: 0;
    }

    .page-two-top {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      align-items: start;
    }

    /* Zauberplätze kompakter */
    .page-two .spellslots {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .page-two .spellslots .quickbox {
      padding: 8px;
    }

    .page-two .spellslots .value {
      font-size: 18px;
    }

    /* Responsive */
    @media (max-width: 1300px) {
      .page-two {
        grid-template-columns: 1fr;
      }

      .page-two-top {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width:1300px) {
      .page {
        grid-template-columns: 1fr;
      }

      .top {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width:800px) {
      .top {
        grid-template-columns: 1fr;
      }

      .abilities {
        grid-template-columns: 1fr;
      }

      .quickstats,
      .grid-2,
      .money,
      .spellslots {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

  <% function sign(n){
   return n >= 0 ? "+" + n : n;
} %>

  <div class="sheet">

    <!-- TOP -->
    <div class="top">

      <div class="grid-2">
        <div class="character-info">
          <div class="card">
            <div class="label">Charaktername</div>
            <div class="value"><%= character.name %></div>
          </div>
          <div class="grid-2-small">
            <div class="card">
              <div class="label">Hintergrund</div>
              <div class="value"><%= character.background %></div>
            </div>
            <div class="card">
              <div class="label">Klasse</div>
              <div class="value"><%= character.class %></div>
            </div>
            <div class="card">
              <div class="label">Volk</div>
              <div class="value"><%= character.species %></div>
            </div>
            <div class="card">
              <div class="label">Unterklasse</div>
              <div class="value"><%= character.subclass %></div>
            </div>
          </div>
        </div>

        <div class="quickbox">
          <div class="card">
            <div class="label">Stufe</div>
            <div class="value"><%= character.level %></div>
          </div>

          <div class="card">
            <div class="label">EP</div>
            <div class="value"><%= character.xp %></div>
          </div>
        </div>
      </div>

      <div class="quickbox">
        <div class="card">
          <div class="label">Rüstungsklasse</div>
          <div class="value"><%= character.armorClass %></div>
        </div>
      </div>

      <div class="quickbox">

        <div style="display:grid; grid-template-columns: 2fr 1fr; gap:10px;">

          <!-- HP BLOCK -->
          <div class="card">

            <div class="label">Trefferpunkte</div>

            <div style="display:flex; gap:10px; align-items:stretch;">

              <!-- Current -->
              <div style="flex:1; text-align:center;">
                <div class="label">Aktuell</div>
                <div class="value"><%= character.currentHitpoints %></div>
              </div>

              <!-- Max + Temp -->
              <div style="flex:1; display:flex; flex-direction:column; gap:6px; text-align:center;">
                <div>
                  <div class="label">Max</div>
                  <div class="value"><%= character.maxHitpoints %></div>
                </div>
                <div>
                  <div class="label">Temp</div>
                  <div class="value"><%= character.temporaryHitpoints %></div>
                </div>
              </div>

            </div>
          </div>

          <!-- HIT DICE -->
          <div class="card" style="text-align:center;">

            <div class="label">Trefferwürfel</div>

            <div style="display:flex; flex-direction:column; gap:8px; margin-top:6px;">
              <div>
                <div class="label">Verbraucht</div>
                <div class="value"><%= character.spentHitDice %></div>
              </div>

              <div>
                <div class="label">Max</div>
                <div class="value"><%= character.level + "W" + character.hitDiceValue %></div>
              </div>
            </div>

          </div>

        </div>

      </div>
      <div class="quickbox">

        <h2 class="section-title">Todesrettungswürfe</h2>

        <div style="display:flex; flex-direction:column; gap:12px;">

          <!-- SUCCESS -->
          <div class="death-column">
            <div class="death-label">Erfolge</div>

            <div class="death-row">
              <div class="skill-check<%= character.successDeathSaves >= 1 ? 'filled' : '' %>"></div>
              <div class="skill-check<%= character.successDeathSaves >= 2 ? 'filled' : '' %>"></div>
              <div class="skill-check<%= character.successDeathSaves >= 3 ? 'filled' : '' %>"></div>
            </div>
          </div>

          <!-- FAILS -->
          <div class="death-column">
            <div class="death-label">Fehlschläge</div>

            <div class="death-row">
              <div class="skill-check<%= character.failedDeathSaves >= 1 ? 'filled' : '' %>"></div>
              <div class="skill-check<%= character.failedDeathSaves >= 2 ? 'filled' : '' %>"></div>
              <div class="skill-check<%= character.failedDeathSaves >= 3 ? 'filled' : '' %>"></div>
            </div>
          </div>

        </div>

      </div>
    </div>

    <!-- PAGE -->
    <div class="firstpage">

      <!-- LEFT -->
      <div class="left">

        <div class="card">
          <h2 class="section-title">Attribute</h2>

          <div class="abilities">

            <div class="abilities-left">
              <div class="mini-stat">
                <div class="label">Übungsbonus</div>
                <div class="value">+<%= character.proficiencyBonus %></div>
              </div>

              <div class="ability">

                <div class="ability-name">Stärke</div>

                <div class="ability-header">

                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.strength.value %>
                    </div>
                  </div>

                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.strength.modifier) %>
                    </div>
                  </div>

                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.strength.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.strength.savingThrow) %></div>
                  <div class="skill-name">Rettungswurf</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.athletics.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.athletics.modifier) %></div>
                  <div class="skill-name">Athletik</div>
                </div>
              </div>

              <div class="ability">
                <div class="ability-name">Geschicklichkeit</div>
                <div class="ability-header">
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.dexterity.value %>
                    </div>
                  </div>
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.dexterity.modifier) %>
                    </div>
                  </div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.dexterity.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.dexterity.savingThrow) %></div>
                  <div class="skill-name">Rettungswurf</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.acrobatics.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.acrobatics.modifier) %></div>
                  <div class="skill-name">Akrobatik</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.sleightOfHand.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.sleightOfHand.modifier) %></div>
                  <div class="skill-name">Fingerfertigkeit</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.stealth.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.stealth.modifier) %></div>
                  <div class="skill-name">Heimlichkeit</div>
                </div>
              </div>

              <div class="ability">
                <div class="ability-name">Konstitution</div>
                <div class="ability-header">
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.constitution.value %>
                    </div>
                  </div>
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.constitution.modifier) %>
                    </div>
                  </div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.constitution.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.constitution.modifier) %></div>
                  <div class="skill-name">Rettungswurf</div>
                </div>
              </div>

              <div class="mini-stat">
                <div class="label">Heroische Inspiration</div>
                <div class="heroic-circle<%= character.heroicInspiration ? 'filled' : '' %>"></div>
              </div>
            </div>

            <div class="abilities-right">
              <div class="ability">
                <div class="ability-name">Intelligenz</div>
                <div class="ability-header">
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.intelligence.value %>
                    </div>
                  </div>
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.intelligence.modifier) %>
                    </div>
                  </div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.arcana.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.arcana.modifier) %></div>
                  <div class="skill-name">Arkane Kunde</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.history.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.history.modifier) %></div>
                  <div class="skill-name">Geschichte</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.investigation.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.investigation.modifier) %></div>
                  <div class="skill-name">Nachforschung</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.nature.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.nature.modifier) %></div>
                  <div class="skill-name">Naturkunde</div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.religion.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.religion.modifier) %></div>
                  <div class="skill-name">Religion</div>
                </div>
              </div>

              <div class="ability">
                <div class="ability-name">Weisheit</div>
                <div class="ability-header">
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.wisdom.value %>
                    </div>
                  </div>
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.wisdom.modifier) %>
                    </div>
                  </div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.wisdom.savingThrow ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.wisdom.savingThrow) %></div>
                  <div class="skill-name">Rettungswurf</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.medicine.proficiency ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.medicine.modifier) %></div>
                  <div class="skill-name">Heilkunde</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.animalHandling.proficiency ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.animalHandling.modifier) %></div>
                  <div class="skill-name">Mit Tieren umgehen</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.insight.proficiency ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.insight.modifier) %></div>
                  <div class="skill-name">Motiv erkennen</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.survival.proficiency ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.survival.modifier) %></div>
                  <div class="skill-name">Überlebenskunst</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.perception.proficiency ? ' filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.perception.modifier) %></div>
                  <div class="skill-name">Wahrnehmung</div>
                </div>
              </div>

              <div class="ability">
                <div class="ability-name">Charisma</div>
                <div class="ability-header">
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Wert</div>
                    <div class="ability-stat-value">
                      <%= character.charisma.value %>
                    </div>
                  </div>
                  <div class="ability-statbox">
                    <div class="ability-stat-label">Mod</div>
                    <div class="ability-stat-mod">
                      <%= sign(character.charisma.modifier) %>
                    </div>
                  </div>
                </div>

                <div class="skill-row">
                  <div class="skill-check<%= character.charisma.savingThrow ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.charisma.savingThrow) %></div>
                  <div class="skill-name">Rettungswurf</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.performance.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.performance.modifier) %></div>
                  <div class="skill-name">Auftreten</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.intimidation.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.intimidation.modifier) %></div>
                  <div class="skill-name">Einschüchtern</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.deception.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.deception.modifier) %></div>
                  <div class="skill-name">Täuschen</div>
                </div>
                <div class="skill-row">
                  <div class="skill-check<%= character.persuasion.proficiency ? 'filled' : '' %>"></div>
                  <div class="skill-mod"><%= sign(character.persuasion.modifier) %></div>
                  <div class="skill-name">Überzeugen</div>
                </div>

              </div>
            </div>

            <!-- Rüstung, Waffen und Werkzeuge -->

          </div>
          <div class="card">

            <div class="section-title">Übung & Kompetenzen</div>

            <!-- RÜSTUNGEN + SCHILD -->
            <div class="label">Rüstung</div>
            <div class="training-grid-4">

              <div class="skill-row">
                <div class="skill-check<%= character.lightArmorTraining ? ' filled' : '' %>"></div>
                <div class="skill-name">Leichte</div>
              </div>

              <div class="skill-row">
                <div class="skill-check<%= character.mediumArmorTraining ? ' filled' : '' %>"></div>
                <div class="skill-name">Mittlere</div>
              </div>

              <div class="skill-row">
                <div class="skill-check<%= character.heavyArmorTraining ? ' filled' : '' %>"></div>
                <div class="skill-name">Schwere</div>
              </div>

              <div class="skill-row">
                <div class="skill-check<%= character.shieldTraining ? ' filled' : '' %>"></div>
                <div class="skill-name">Schilde</div>
              </div>

            </div>

            <!-- WAFFEN -->
            <div class="label">Waffen</div>
            <div class="training-grid-2" style="margin-top:12px;">

              <div class="skill-row">
                <div class="skill-check<%= character.weaponTrainingSimple ? ' filled' : '' %>"></div>
                <div class="skill-name">Einfache</div>
              </div>

              <div class="skill-row">
                <div class="skill-check<%= character.weaponTrainingMartial ? ' filled' : '' %>"></div>
                <div class="skill-name">Kriegswaffen</div>
              </div>

            </div>

            <!-- WERKZEUGE -->
            <div style="margin-top:12px;">
              <div class="label">Werkzeuge</div>

              <% if(character.toolProficiencies && character.toolProficiencies.length > 0 ) { %>
              <div class="tool-list">
                <% if(character.toolProficiencies && character.toolProficiencies.length > 0) { %>
                <div><%= character.toolProficiencies.join(", ") %></div>
                <% } else { %>
                <div class="skill-row">
                  <div class="skill-check"></div>
                  <div class="skill-name" style="color:var(--muted);">Keine</div>
                </div>
                <% } %>
              </div>
              <% } else { %>
              <div class="skill-row">
                <div class="skill-name" style="color:var(--muted);">Keine</div>
              </div>
              <% } %>

            </div>

          </div>
        </div>
      </div>

      <!-- CENTER -->
      <div class="center">

        <div class="card">
          <div class="quickstats">

            <div class="quickbox">
              <div class="label">Initiative</div>
              <div class="value"><%= sign(character.initiative) %></div>
            </div>

            <div class="quickbox">
              <div class="label">Bewegungsrate</div>
              <div class="value"><%= character.speed %></div>
            </div>

            <div class="quickbox">
              <div class="label">Größe</div>
              <div class="value"><%= character.size %></div>
            </div>

            <div class="quickbox">
              <div class="label">Passive Wahrnehmung</div>
              <div class="value"><%= character.passivePerception %></div>
            </div>
          </div>
        </div>

        <div class="card">
          <h2 class="section-title">Waffen & Angriffszauber</h2>

          <table>
            <tr>
              <th>Name</th>
              <th>Bonus/SG</th>
              <th>Schaden</th>
              <th>Art</th>
              <th>Notizen</th>
            </tr>

            <% character.weapons.forEach(w=>{ %>
            <tr>
              <td><%= w.name %></td>
              <td><%= sign(w.attackBonus) + "/" + sign(w.difficultyBonus) %></td>
              <td><%= w.damage %></td>
              <td><%= w.damageType %></td>
              <td><%= w.notes %></td>
            </tr>
            <% }) %>

            <% character.damageCantrips.forEach(w=>{ %>
            <tr>
              <td><%= w.name %></td>
              <td><%= sign(w.attackBonus) + "/" + sign(w.difficultyBonus) %></td>
              <td><%= w.damage %></td>
              <td><%= w.damageType %></td>
              <td><%= w.notes %></td>
            </tr>
            <% }) %>

          </table>
        </div>

        <div class="grid-2">

          <div class="card">
            <h2 class="section-title">Klassenmerkmale</h2>
            <ul class="list">
              <% character.classFeatures.forEach(x=>{ %>
              <li><%= x %></li>
              <% }) %>
            </ul>
          </div>

          <div class="card">
            <h2 class="section-title">Volksmerkmale</h2>
            <ul class="list">
              <% character.speciesTraits.forEach(x=>{ %>
              <li><%= x %></li>
              <% }) %>
            </ul>
          </div>

        </div>

        <div class="card">
          <h2 class="section-title">Talente</h2>
          <ul class="list">
            <% character.feats.forEach(x=>{ %>
            <li><%= x %></li>
            <% }) %>
          </ul>
        </div>
      </div>

      <br />
    </div>
    <!-- PAGE 2 -->
    <div class="page-two">

      <!-- LINKS 2/3 -->
      <div class="page-two-left">

        <!-- OBERER BEREICH -->
        <div class="page-two-top">

          <!-- ZAUBERSTATS -->
          <div class="card">
            <h2 class="section-title">Zauberwirken</h2>

            <div class="quickstats">
              <div class="quickbox">
                <div class="label">Attribut</div>
                <div class="value"><%= character.spellcastingAbility || 'Keins' %></div>
              </div>

              <div class="quickbox">
                <div class="label">Mod</div>
                <div class="value">
                  <%= sign(character.spellAttackBonus - character.proficiencyBonus) %>
                </div>
              </div>

              <div class="quickbox">
                <div class="label">SG</div>
                <div class="value"><%= character.spellSaveDC %></div>
              </div>

              <div class="quickbox">
                <div class="label">Angriff</div>
                <div class="value"><%= sign(character.spellAttackBonus) %></div>
              </div>
            </div>
          </div>

          <!-- ZAUBERPLÄTZE -->
          <div class="card">
            <h2 class="section-title">Zauberplätze</h2>

            <div class="spellslots-grid">

              <% for(let i = 1; i <= 9; i++){ 
                const total = character["totalSpellSlots" + i] || 0;
                const used  = character["usedSpellSlots" + i] || 0;
                if(total === 0) continue;
              %>

              <div class="slot-card">

                <div class="slot-top">
                  <span class="slot-grade">Grad <%= i %></span>

                  <div class="slot-right">
                    <div class="slot-gems">
                      <% for(let j = 1; j <= 4; j++){ %>

                      <% if(j <= total){ %>
                      <div class="gem <%= j <= used ? 'used' : 'free' %>"></div>
                      <% } else { %>
                      <div class="gem hidden"></div>
                      <% } %>

                      <% } %>
                    </div>
                  </div>
                </div>

              </div>


              <% } %>

            </div>
          </div>

        </div>

        <!-- ZAUBER -->
        <div class="card">
          <h2 class="section-title">Zaubertricks & Vorbereitete Zauber</h2>

          <table>
            <tr>
              <th>Grad</th>
              <th>Name</th>
              <th>Aufwand</th>
              <th>Reichweite</th>
              <th>Konzentration</th>
              <th>Ritual</th>
              <th>Materiallien</th>
              <th>Notizen</th>
            </tr>

            <% character.cantripsAndPreparedSpells.forEach(spell=>{ %>
            <tr>
              <td><%= spell.Stufe %></td>
              <td><a href="/spell/<%= spell.Name %>" target="_blank"><%= spell.Name %></a></td>
              <td><%= spell.Zeitaufwand %></td>
              <td><%= spell.Reichweite %></td>
              <td><%= spell.Konzentration %></td>
              <td><%= spell.Ritual %></td>
              <td><%= spell.Materialien %></td>
              <td><%= spell.Notizen %></td>
            </tr>
            <% }) %>

          </table>
        </div>

      </div>

      <!-- RECHTS 1/3 -->
      <div class="page-two-right">

        <div class="card">
          <h2 class="section-title">Aussehen</h2>
          <div><%= character.appearance %></div>
        </div>

        <div class="card">
          <h2 class="section-title">Hintergrundgeschichte</h2>
          <div><%= character.backstory %></div>
        </div>

        <div class="card">
          <h2 class="section-title">Gesinnung</h2>
          <div><%= character.alignment %></div>
        </div>

        <div class="card">
          <h2 class="section-title">Sprachen</h2>
          <ul class="list">
            <% character.languages.forEach(x=>{ %>
            <li><%= x %></li>
            <% }) %>
          </ul>
        </div>

        <div class="card">
          <h2 class="section-title">Ausrüstung</h2>
          <ul class="list">
            <% character.equipment.forEach(x=>{ %>
            <li><%= x %></li>
            <% }) %>
          </ul>
        </div>

        <div class="card">
          <h2 class="section-title">Eingestimmte magische Gegenstände</h2>
          <ul class="list">
            <% character.attunedMagicItems.forEach(x=>{ %>
            <li><%= x %></li>
            <% }) %>
          </ul>
        </div>

        <div class="card">
          <h2 class="section-title">Münzen</h2>

          <div class="money">

            <div class="quickbox">
              <div class="label">KM</div>
              <div class="value"><%= character.copper %></div>
            </div>

            <div class="quickbox">
              <div class="label">SM</div>
              <div class="value"><%= character.silver %></div>
            </div>

            <div class="quickbox">
              <div class="label">EM</div>
              <div class="value"><%= character.electrum %></div>
            </div>

            <div class="quickbox">
              <div class="label">GM</div>
              <div class="value"><%= character.gold %></div>
            </div>

            <div class="quickbox">
              <div class="label">PM</div>
              <div class="value"><%= character.platinum %></div>
            </div>

          </div>
        </div>

      </div>

    </div>
  </div>

</body>

</html>