<!DOCTYPE html>
<html lang="de">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= character.name %> – Charakterbogen</title>

  <style>
    :root {
      --bg: #1e1f22;
      --panel: #2b2d31;
      --panel2: #33363c;
      --line: #4b4f57;
      --text: #f5f5f5;
      --muted: #b8bcc5;
      --green: #57d37c;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      background: var(--bg);
      color: var(--text);
      font-family: Arial, Helvetica, sans-serif;
    }

    .sheet {
      max-width: 1600px;
      margin: auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 14px;
    }

    .section-title {
      margin: 0 0 12px 0;
      font-size: 18px;
      font-weight: 700;
      border-bottom: 1px solid var(--line);
      padding-bottom: 8px;
    }

    .label {
      font-size: 12px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .value {
      font-size: 18px;
      font-weight: 700;
    }

    .top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
      gap: 14px;
    }

    .page {
      display: grid;
      grid-template-columns: 340px 1fr 360px;
      gap: 20px;
    }

    .left,
    .center,
    .right {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .abilities {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .ability {
      background: var(--panel2);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    .ability-name {
      font-size: 14px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .ability-score {
      font-size: 32px;
      font-weight: 700;
      margin-top: 8px;
    }

    .ability-mod {
      font-size: 18px;
      color: var(--green);
    }

    .ability-proficiency {
      font-size: 18px;
    }

    .quickstats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .quickbox {
      background: var(--panel2);
      border-radius: 12px;
      padding: 12px;
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th,
    td {
      padding: 8px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }

    th {
      color: var(--muted);
      font-size: 13px;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .list {
      margin: 0;
      padding-left: 18px;
    }

    .list li {
      margin-bottom: 6px;
    }

    .money {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
    }

    .money .quickbox {
      padding: 10px;
    }

    .spellslots {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    textarea.fake {
      width: 100%;
      min-height: 180px;
      resize: none;
      border: none;
      background: var(--panel2);
      color: var(--text);
      border-radius: 12px;
      padding: 12px;
    }

    @media (max-width:1300px) {
      .page {
        grid-template-columns: 1fr;
      }

      .top {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width:800px) {
      .top {
        grid-template-columns: 1fr;
      }

      .abilities {
        grid-template-columns: 1fr;
      }

      .quickstats,
      .grid-2,
      .money,
      .spellslots {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

<body>

<% function sign(n){
   return n >= 0 ? "+" + n : n;
} %>

  <div class="sheet">

    <!-- TOP -->
    <div class="top">

      <div class="grid-2">
        <div class="quickbox">
          <div class="card">
            <div class="label">Charaktername</div>
            <div class="value"><%= character.name %></div>
          </div>
          <div class="grid-2">
            <div class="card">
              <div class="label">Hintergrund</div>
              <div class="value"><%= character.background %></div>
            </div>
            <div class="card">
              <div class="label">Klasse</div>
              <div class="value"><%= character.class %></div>
            </div>
            <div class="card">
              <div class="label">Volk</div>
              <div class="value"><%= character.species %></div>
            </div>
            <div class="card">
              <div class="label">Unterklasse</div>
              <div class="value"><%= character.subclass %></div>
            </div>
          </div>
        </div>

        <div class="quickbox">
          <div class="card">
            <div class="label">Stufe</div>
            <div class="value"><%= character.level %></div>
          </div>

          <div class="card">
            <div class="label">EP</div>
            <div class="value"><%= character.xp %></div>
          </div>
        </div>
      </div>

      <div class="quickbox">
        <div class="card">
          <div class="label">Rüstungsklasse</div>
          <div class="value"><%= character.armorClass %></div>
        </div>
      </div>

      <div class="quickbox">
        <h2 class="section-title">Trefferpunkte</h2>

        <div class="quickstats">

          <div class="card">
            <div class="label">Aktuell</div>
            <div class="value"><%= character.currentHitpoints %></div>
          </div>

          <div class="grid-2">
            <div class="card">
              <div class="label">Maximal</div>
              <div class="value"><%= character.maxHitpoints %></div>
            </div>

            <div class="card">
              <div class="label">Temporär</div>
              <div class="value"><%= character.temporaryHitpoints %></div>
            </div>
          </div>
        </div>
        <div class="quickbox">
          <h2 class="section-title">Trefferwürfel</h2>
          <div class="card">
            <div class="value"><%= character.currentHitDice %></div>
            <div class="label">Verbraucht</div>
          </div>
          <div class="card">
            <div class="value"><%= character.maxHitDice %></div>
            <div class="label">Maximal</div>
          </div>
        </div>

      </div>
      <div class="quickbox">
        <h2 class="section-title">Todesrettungswürfe</h2>

      </div>
    </div>

    <!-- PAGE -->
    <div class="page">

      <!-- LEFT -->
      <div class="left">

        <div class="card">
          <h2 class="section-title">Attribute</h2>

          <div class="abilities">

            <div class="quickbox">
              <div class="label">Übungsbonus</div>
              <div class="value">+<%= character.proficiencyBonus %></div>
            </div>

            <div class="ability">
              <div class="ability-name">Stärke</div>
              <div class="grid-2">
                <div class="ability-mod"><%= sign(character.strength.modifier) %></div>
                <div class="ability-score"><%= character.strength.value %></div>
              </div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.strength.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.strength.proficiency %></div>

              <div class="ability-name">Athletik</div>
              <div class="ability-mod"><%= sign(character.athletics.modifier) %></div>
              <div class="ability-proficiency"><%= character.athletics.proficiency %></div>
            </div>

            <div class="ability">
              <div class="ability-name">Geschicklichkeit</div>
              <div class="ability-mod"><%= sign(character.dexterity.modifier) %></div>
              <div class="ability-score"><%= character.dexterity.value %></div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.dexterity.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.dexterity.proficiency %></div>

              <div class="ability-name">Akrobatik</div>
              <div class="ability-mod"><%= sign(character.acrobatics.modifier) %></div>
              <div class="ability-proficiency"><%= character.acrobatics.proficiency %></div>

              <div class="ability-name">Fingerfertigkeit</div>
              <div class="ability-mod"><%= sign(character.sleightOfHand.modifier) %></div>
              <div class="ability-proficiency"><%= character.sleightOfHand.proficiency %></div>

              <div class="ability-name">Heimlichkeit</div>
              <div class="ability-mod"><%= sign(character.stealth.modifier) %></div>
              <div class="ability-proficiency"><%= character.stealth.proficiency %></div>
            </div>

            <div class="ability">
              <div class="ability-name">Konstitution</div>
              <div class="ability-mod"><%= sign(character.constitution.modifier) %></div>
              <div class="ability-score"><%= character.constitution.value %></div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.constitution.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.constitution.proficiency %></div>
            </div>

            <div class="ability">
              <div class="ability-name">Intelligenz</div>
              <div class="ability-score"><%= character.intelligence.value %></div>
              <div class="ability-mod"><%= sign(character.intelligence.modifier) %></div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.intelligence.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.intelligence.proficiency %></div>

              <div class="ability-name">Arkane Kunde</div>
              <div class="ability-mod"><%= sign(character.arcana.modifier) %></div>
              <div class="ability-proficiency"><%= character.arcana.proficiency %></div>

              <div class="ability-name">Geschichte</div>
              <div class="ability-mod"><%= sign(character.history.modifier) %></div>
              <div class="ability-proficiency"><%= character.history.proficiency %></div>

              <div class="ability-name">Nachforschen</div>
              <div class="ability-mod"><%= sign(character.investigation.modifier) %></div>
              <div class="ability-proficiency"><%= character.investigation.proficiency %></div>

              <div class="ability-name">Naturkunde</div>
              <div class="ability-mod"><%= sign(character.nature.modifier) %></div>
              <div class="ability-proficiency"><%= character.nature.proficiency %></div>

              <div class="ability-name">Religion</div>
              <div class="ability-mod"><%= sign(character.religion.modifier) %></div>
              <div class="ability-proficiency"><%= character.religion.proficiency %></div>

            </div>

            <div class="ability">
              <div class="ability-name">Weisheit</div>
              <div class="ability-mod"><%= sign(character.wisdom.modifier) %></div>
              <div class="ability-score"><%= character.wisdom.value %></div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.wisdom.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.wisdom.proficiency %></div>

              <div class="ability-name">Heilkunde</div>
              <div class="ability-mod"><%= sign(character.medicine.modifier) %></div>
              <div class="ability-proficiency"><%= character.medicine.proficiency %></div>

              <div class="ability-name">Mit Tieren umgehen</div>
              <div class="ability-mod"><%= sign(character.animalHandling.modifier) %></div>
              <div class="ability-proficiency"><%= character.animalHandling.proficiency %></div>

              <div class="ability-name">Motiv erkennen</div>
              <div class="ability-mod"><%= sign(character.insight.modifier) %></div>
              <div class="ability-proficiency"><%= character.insight.proficiency %></div>

              <div class="ability-name">Überlebenskunst</div>
              <div class="ability-mod"><%= sign(character.survival.modifier) %></div>
              <div class="ability-proficiency"><%= character.survival.proficiency %></div>

              <div class="ability-name">Wahrnehmung</div>
              <div class="ability-mod"><%= sign(character.perception.modifier) %></div>
              <div class="ability-proficiency"><%= character.perception.proficiency %></div>
            </div>

            <div class="ability">
              <div class="ability-name">Charisma</div>
              <div class="ability-mod"><%= sign(character.charisma.modifier) %></div>
              <div class="ability-score"><%= character.charisma.value %></div>

              <div class="ability-name">Rettungswurf</div>
              <div class="ability-mod"><%= sign(character.charisma.savingThrow) %></div>
              <div class="ability-proficiency"><%= character.charisma.proficiency %></div>

              <div class="ability-name">Auftreten</div>
              <div class="ability-mod"><%= sign(character.performance.modifier) %></div>
              <div class="ability-proficiency"><%= character.performance.proficiency %></div>

              <div class="ability-name">Einschüchtern</div>
              <div class="ability-mod"><%= sign(character.intimidation.modifier) %></div>
              <div class="ability-proficiency"><%= character.intimidation.proficiency %></div>

              <div class="ability-name">Täuschen</div>
              <div class="ability-mod"><%= sign(character.deception.modifier) %></div>
              <div class="ability-proficiency"><%= character.deception.proficiency %></div>

              <div class="ability-name">Überzeugen</div>
              <div class="ability-mod"><%= sign(character.persuasion.modifier) %></div>
              <div class="ability-proficiency"><%= character.persuasion.proficiency %></div>

            </div>

            <!-- Rüstung, Waffen und Werkzeuge -->

          </div>
        </div>
      </div>

      <!-- CENTER -->
      <div class="center">

        <div class="card">
          <div class="card">
            <div class="quickstats">

              <div class="quickbox">
                <div class="label">Initiative</div>
                <div class="value"><%= sign(character.initiative) %></div>
              </div>

              <div class="quickbox">
                <div class="label">Bewegungsrate</div>
                <div class="value"><%= character.speed %></div>
              </div>

              <div class="quickbox">
                <div class="label">Größe</div>
                <div class="value"><%= character.size %></div>
              </div>

              <div class="quickbox">
                <div class="label">Passive Wahrnehmung</div>
                <div class="value"><%= character.passivePerception %></div>
              </div>
            </div>
          </div>

        </div>

        <div class="card">
          <h2 class="section-title">Waffen & Angriffszauber</h2>

          <table>
            <tr>
              <th>Name</th>
              <th>Bonus</th>
              <th>SG</th>
              <th>Schaden</th>
              <th>Art</th>
              <th>Notizen</th>
            </tr>

<% character.weapons.forEach(w=>{ %>
            <tr>
              <td><%= w.name %></td>
              <td>+<%= w.attackBonus %></td>
              <td><%= w.damage %></td>
              <td><%= w.type %></td>
              <td><%= w.notes %></td>
            </tr>
<% }) %>

<% character.damageCantrips.forEach(w=>{ %>
            <tr>
              <td><%= w.name %></td>
              <td>+<%= w.attackBonus %></td>
              <td><%= w.damage %></td>
              <td><%= w.type %></td>
              <td><%= w.notes %></td>
            </tr>
<% }) %>

          </table>
        </div>

        <div class="grid-2">

          <div class="card">
            <h2 class="section-title">Klassenmerkmale</h2>
            <ul class="list">
<% character.classFeatures.forEach(x=>{ %>
              <li><%= x %></li>
<% }) %>
            </ul>
          </div>

          <div class="card">
            <h2 class="section-title">Volksmerkmale</h2>
            <ul class="list">
<% character.speciesTraits.forEach(x=>{ %>
              <li><%= x %></li>
<% }) %>
            </ul>
          </div>

        </div>

        <div class="card">
          <h2 class="section-title">Talente</h2>
          <ul class="list">
<% character.feats.forEach(x=>{ %>
            <li><%= x %></li>
<% }) %>
          </ul>
        </div>
      </div>

      <br />
      <!-- RIGHT -->
      <div class="page">

        <div class="card">
          <h2 class="section-title">Zauberwirken</h2>

          <div class="quickstats">
            <div class="quickbox">
              <div class="label">Attribut</div>
              <div class="value"><%= character.spellcastingAbility %></div>
            </div>

            <div class="quickbox">
              <div class="label">Mod</div>
              <div class="value"><%= sign(character.spellAttackBonus - character.proficiencyBonus) %></div>
            </div>

            <div class="quickbox">
              <div class="label">SG</div>
              <div class="value"><%= character.spellSaveDC %></div>
            </div>

            <div class="quickbox">
              <div class="label">Angriff</div>
              <div class="value">+<%= character.spellAttackBonus %></div>
            </div>
          </div>

        </div>

        <div class="card">
          <h2 class="section-title">Zauberplätze</h2>

          <div class="spellslots">

<% for(let i=1;i<=9;i++){ %>
            <div class="quickbox">
              <div class="label">Grad<%= i %></div>
              <div class="value">
<%= character["usedSpellSlots"+i] %>/<%= character["totalSpellSlots"+i] %>
              </div>
            </div>
<% } %>

          </div>
        </div>

        <div class="card">
          <h2 class="section-title">Zauber</h2>

          <table>
            <tr>
              <th>Name</th>
              <th>Grad</th>
            </tr>

<% character.cantripsAndPreparedSpells.forEach(spell=>{ %>
            <tr>
              <td><%= spell.name %></td>
              <td><%= spell.level %></td>
            </tr>
<% }) %>

          </table>
        </div>

        <div class="card">
          <h2 class="section-title">Sprachen</h2>
          <ul class="list">
<% character.languages.forEach(x=>{ %>
            <li><%= x %></li>
<% }) %>
          </ul>
        </div>

        <div class="card">
          <h2 class="section-title">Ausrüstung</h2>
          <ul class="list">
<% character.equipment.forEach(x=>{ %>
            <li><%= x %></li>
<% }) %>
          </ul>
        </div>

        <div class="card">
          <h2 class="section-title">Münzen</h2>

          <div class="money">

            <div class="quickbox">
              <div class="label">KM</div>
              <div class="value"><%= character.copper %></div>
            </div>
            <div class="quickbox">
              <div class="label">SM</div>
              <div class="value"><%= character.silver %></div>
            </div>
            <div class="quickbox">
              <div class="label">EM</div>
              <div class="value"><%= character.electrum %></div>
            </div>
            <div class="quickbox">
              <div class="label">GM</div>
              <div class="value"><%= character.gold %></div>
            </div>
            <div class="quickbox">
              <div class="label">PM</div>
              <div class="value"><%= character.platinum %></div>
            </div>

          </div>
        </div>

      </div>

    </div>

    <!-- BOTTOM ROLEPLAY -->
    <div class="grid-2">

      <div class="card">
        <h2 class="section-title">Aussehen</h2>
        <div><%= character.appearance %></div>
      </div>

      <div class="card">
        <h2 class="section-title">Hintergrundgeschichte & Persönlichkeit</h2>
        <div><%= character.backstory %></div>
      </div>

    </div>

  </div>

</body>

</html>