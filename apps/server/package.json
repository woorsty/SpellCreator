{
  "name": "@repo/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build-tsc": "tsc && npm run copy-assets",
    "build": "esbuild src/server.ts --bundle --platform=node --outfile=dist/server.js",
    "start": "node dist/server.js",
    "copy-assets": "cpx \"src/assets/**/*\" dist/assets"
  },
  "dependencies": {
    "@repo/domain": "workspace:*",
    "@repo/i18n": "workspace:*",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "jspdf": "^3.0.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.1",
    "@types/node": "^22.19.17",
    "@types/pdfkit": "^0.14.0",
    "cpx": "^1.5.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
