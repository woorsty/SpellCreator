{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react",
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "skipLibCheck": true,
    "lib": ["ES2021.String"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "src/**/*.spec.ts"]
}
